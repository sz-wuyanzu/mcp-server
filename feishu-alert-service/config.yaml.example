# Feishu Alert Service 配置

# 飞书应用凭证（与 Hermes 共用同一个应用）
feishu:
  app_id: "cli_xxx"
  app_secret: "xxx"
  # domain: feishu  # 或 lark（海外版）

# LLM 配置
llm:
  base_url: "https://ai.sisensing.com/v1"
  api_key: "sk-xxx"
  model: "glm-5"

# 全局默认值（可被每个群覆盖）
defaults:
  segment_interval: 10       # 分段摘要间隔（分钟）
  report_interval: 240       # 归总报告间隔（分钟）
  max_chars_per_fetch: 30000 # 每次拉取的最大字符数

# 自定义提示词（可选，不指定则使用内置默认）
# segment_prompt: |
#   你是一个运维告警分析助手。以下是最近一段时间的飞书群消息（包含告警和普通对话）。
#   请提取并总结其中的告警信息，按服务/模块分类，标注严重程度和出现次数。
#   忽略普通闲聊。如果没有告警消息，回复'无告警'。
#   用简洁的中文输出，不要超过 500 字。

# report_prompt: |
#   你是一个运维告警分析助手。以下是过去一段时间内多个时间段的告警摘要。
#   请将它们归总为一份完整的告警报告：
#   1. 按服务/模块分类汇总
#   2. 标注每类告警的总出现次数和时间范围
#   3. 高亮最严重或最频繁的问题
#   4. 如果所有摘要都是'无告警'，回复'本周期内无告警'
#   用简洁的中文输出。

# MCP Server 配置（供 Hermes 查询群历史）
mcp:
  enabled: true
  port: 8765

# 监控的群列表
chats:
  - chat_id: "oc_xxxxxxxxxxxxx1"
    name: "生产-CGM日志告警群"
    segment_interval: 10
    report_interval: 120

  - chat_id: "oc_xxxxxxxxxxxxx2"
    name: "基础设施告警群"
    segment_interval: 30
    report_interval: 480
